{
  "name": "@apps/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 51002",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "workers:preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "workers:deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "workers:upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "vercel:preview": "vercel",
    "vercel:deploy": "vercel --prod",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "clean": "rm -rf .next .open-next node_modules .turbo"
  },
  "dependencies": {
    "@apps/api": "workspace:*",
    "@opennextjs/cloudflare": "^1.14.8",
    "@packages/cms-microcms": "workspace:*",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "hono": "^4.11.4",
    "lucide-react": "^0.563.0",
    "next": "^15.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.5.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.1",
    "@eslint/js": "^9.39.2",
    "@next/eslint-plugin-next": "^16.1.4",
    "@packages/config": "workspace:*",
    "@tailwindcss/postcss": "^4.1.17",
    "@tailwindcss/typography": "^0.5.19",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.1.17",
    "tw-animate-css": "^1.4.0",
    "typescript-eslint": "^8.53.1"
  }
}
