{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ui-next-template-api",
  "main": "src/index.ts",
  "compatibility_date": "2025-12-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
  },
  "placement": { "mode": "smart" },
}
