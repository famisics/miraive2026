{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalPassThroughEnv": [
    "TURSO_DATABASE_URL",
    "TURSO_AUTH_TOKEN",
    "SUPABASE_DATABASE_URL",
    "MICROCMS_SERVICE_DOMAIN",
    "MICROCMS_API_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", ".open-next/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "lint:fix": {},
    "typecheck": {},
    "format": {
      "cache": false
    },
    "clean": {
      "cache": false
    },
    "preview": {
      "cache": false
    },
    "deploy": {
      "dependsOn": ["build"],
      "cache": false
    }
  }
}
